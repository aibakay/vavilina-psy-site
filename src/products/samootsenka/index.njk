---
layout: layout.njk
---
<header class="site-header pp-header" data-reveal>
  <a class="brand" href="/" aria-label="На главную">
    <span>{{ site.brand.name }}</span>
    <small>{{ site.brand.tagline }}</small>
  </a>
  <div class="site-nav-back">
    <a class="pp-back" href="/#products">← Все продукты</a>
    <a class="nav-cta" href="#buy">Купить</a>
  </div>
</header>

<main id="top">
  <section class="section pp-hero" data-reveal>
    <a class="pp-breadcrumb" href="/#products">← Продукты и материалы</a>
    <span class="product-badge">{{ page.badge }}</span>
    <h1>{{ page.name }}</h1>
    <p class="lead">{{ page.lead }}</p>
    <div class="pp-facts">
      {%- for fact in page.facts %}
      <div class="pp-fact"><span>{{ fact.label }}</span><strong>{{ fact.value }}</strong></div>
      {%- endfor %}
    </div>
    <div class="pp-actions">
      <a class="button button-primary" href="#buy">{{ page.primaryCta }}</a>
      <a class="button button-secondary" href="/#products">Другие продукты</a>
    </div>
  </section>

  <section class="section pp-section" data-reveal>
    <h2>Кому подойдёт</h2>
    <p class="pp-intro">{{ page.audience.intro }}</p>
    <ul class="pp-checklist">
      {%- for item in page.audience.items %}
      <li>{{ item }}</li>
      {%- endfor %}
    </ul>
  </section>

  <section class="pp-section pp-band" data-reveal>
    <h2>{{ page.inside.title }}</h2>
    <ul class="pp-checklist">
      {%- for item in page.inside.items %}
      <li>{{ item }}</li>
      {%- endfor %}
    </ul>
  </section>

  <section class="section pp-section" data-reveal>
    <h2>Что входит дополнительно</h2>
    <div class="pp-bonus-grid">
      {%- for bonus in page.bonuses %}
      <div class="pp-bonus">
        <strong>{{ bonus.title }}</strong>
        <p>{{ bonus.text }}</p>
      </div>
      {%- endfor %}
    </div>
  </section>

  <section class="section pp-section" data-reveal>
    <h2>Авторы</h2>
    <div class="pp-authors">
      {%- for author in page.authors %}
      <div class="pp-author">
        {%- if author.image %}
        <img class="pp-author-photo" src="{{ author.image }}" alt="{{ author.name }}" loading="lazy" />
        {%- else %}
        <span class="pp-author-photo pp-author-photo--empty" aria-hidden="true">{{ author.name | first }}</span>
        {%- endif %}
        <span class="pp-author-text">
          <strong>{{ author.name }}</strong>
          <span>{{ author.role }}</span>
        </span>
      </div>
      {%- endfor %}
    </div>
  </section>

  <section class="section pp-buy" id="buy" data-reveal>
    <h2>{{ page.offer.title }}</h2>
    <div class="tier-grid">
      {%- for tier in page.offer.tiers %}
      <div class="tier-card{% if tier.featured %} featured{% endif %}">
        <span class="product-badge">{{ tier.badge }}</span>
        <p class="tier-price">{{ tier.price }}</p>
        <ul class="offer-list">
          {%- for point in tier.points %}
          <li>{{ point }}</li>
          {%- endfor %}
        </ul>
        <a class="button {% if tier.featured %}button-primary{% else %}button-secondary{% endif %}" href="{{ tier.buyUrl }}" target="_blank" rel="noopener noreferrer">{{ tier.buyLabel }}</a>
      </div>
      {%- endfor %}
    </div>
    <p class="pp-note">Материал защищён авторским правом</p>
  </section>
</main>

<footer class="site-footer">
  <div>
    <strong>{{ site.brand.name }}</strong>
    <p>{{ site.legal.entity }}</p>
    <p>{{ site.legal.inn }}</p>
    <p>{{ site.legal.hours }}</p>
  </div>
  <nav aria-label="Документы">
    {%- for doc in site.legal.documents %}
    <a href="{{ doc.url }}" target="_blank" rel="noopener noreferrer">{{ doc.label }}</a>
    {%- endfor %}
  </nav>
</footer>
